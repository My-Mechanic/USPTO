# Copy to .env for local builds. Do NOT commit .env.
#
# Local automation bridge used by "Sync Now" for private/pending applications.
# Only reachable when you run the app locally (http://localhost). Leave default.
VITE_SYNC_BRIDGE_URL=http://127.0.0.1:8787
#
# Optional: override the Pages base path when building (CI sets this to /USPTO/).
# VITE_BASE=/USPTO/
#
# NOTE: There is intentionally no API-key variable here. Your USPTO ODP key is
# entered in the app UI and stored only in your browser (localStorage), never
# baked into the built site.
